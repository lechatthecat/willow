pub fn add(a: i64, b: i64) -> i64 {
    return a + b;
}

pub fn sub(a: i64, b: i64) -> i64 {
    return a - b;
}

pub fn mul(a: i64, b: i64) -> i64 {
    return a * b;
}

pub fn max(a: i64, b: i64) -> i64 {
    return a > b ? a : b;
}

pub fn min(a: i64, b: i64) -> i64 {
    return a < b ? a : b;
}

pub fn abs(n: i64) -> i64 {
    return n < 0 ? -n : n;
}
