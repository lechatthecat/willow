pub open class Shape {
    sides: i64;

    pub open fn label(self) -> i64 {
        return 0;
    }
}

pub open class Triangle extends Shape {
    pub open override fn label(self) -> i64 {
        return 3;
    }
}

pub class UnitTriangle extends Triangle {
    pub override fn label(self) -> i64 {
        return 1;
    }
}

fn main() {
    println(3);
}
