// Cooperative yield: each worker voluntarily gives the scheduler another
// scheduling opportunity without registering a timer. With five workers the
// two tasks may interleave in either order, while each task's own order holds.

async fn worker(id: i64) -> i64 {
    println(id);
    await yield();
    println(id + 10);
    return id;
}

fn main() {
    let a = worker(1);
    let b = worker(2);
    println(a.join() + b.join());
}
